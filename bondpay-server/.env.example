PORT=3000
NODE_ENV=development

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxxxx.supabase.co:5432/postgres

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Server Ed25519 Key Pair (base64 encoded)
# Generate with: node -e "const ed=require('@noble/ed25519');const sk=ed.utils.randomPrivateKey();console.log(Buffer.from(sk).toString('base64'))"
SERVER_PRIVATE_KEY=your-base64-server-private-key
SERVER_PUBLIC_KEY=your-base64-server-public-key

# CORS
CORS_ORIGIN=http://localhost:8081
